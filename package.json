{
  "name": "strategic-report-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ALTO Strategic Report Agent — Cloudflare Worker + Pages",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build:css": "tailwindcss -i css/tailwind.input.css -o css/tailwind.css --minify",
    "watch:css": "tailwindcss -i css/tailwind.input.css -o css/tailwind.css --watch",
    "generate:legal-manuals": "node scripts/generate-legal-chile-manuals.mjs",
    "lint": "eslint src/worker/**/*.js js/**/*.js",
    "lint:fix": "eslint src/worker/**/*.js js/**/*.js --fix",
    "test": "node --test tests/**/*.test.mjs",
    "format": "prettier --write '**/*.{js,json,css,html}' --ignore-path .gitignore",
    "format:check": "prettier --check '**/*.{js,json,css,html}' --ignore-path .gitignore"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.19",
    "wrangler": "^3.0.0"
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
